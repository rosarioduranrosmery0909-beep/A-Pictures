# CORS Configuration (default: http://localhost:3000)
# CORS_ORIGIN=http://localhost:3000

# Database Path Configuration
# For shared database on network, use a network path:
# Windows: DATABASE_PATH=\\NETWORK_SERVER\shared_folder\database.db
# Linux/Mac: DATABASE_PATH=/mnt/network/shared_folder/database.db
# Default: ./database.db (local)
# DATABASE_PATH=

# Node environment
# NODE_ENV=production
